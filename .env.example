# Provider/model — Pydantic AI "provider:model" string.
# Examples: anthropic:claude-sonnet-4-5 | openai:gpt-4o-mini | ollama:llama3.1
EMPORIO_MODEL=anthropic:claude-sonnet-4-5

# API key for the chosen provider (only the one you use is needed).
# Not required when EMPORIO_OPENAI_BASE_URL points at a local server below.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Self-hosted / local model (any OpenAI-compatible server: vLLM, Ollama, LM
# Studio, llama.cpp, TGI, LocalAI, ...). Set the base URL + the served model
# name in EMPORIO_MODEL; the API key may stay empty. Embeddings are local
# regardless, so this runs the whole system with zero paid API.
#   EMPORIO_MODEL=qwen2.5:7b
#   EMPORIO_OPENAI_BASE_URL=http://localhost:11434/v1   # host; in Docker use host.docker.internal

# Optional overrides.
# EMPORIO_EMBEDDING_MODEL=BAAI/bge-m3
# EMPORIO_RETRIEVAL_TOP_K=3
# EMPORIO_DATA_DIR=./data
